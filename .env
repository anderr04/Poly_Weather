# ============================================================
#  Poly_Weather — Environment Variables
#  Copy to .env and fill in your values
# ============================================================

# ── Mode ─────────────────────────────────────────────────────
PAPER_MODE=true
INITIAL_CAPITAL=100.0
LOG_LEVEL=INFO

# ── Polymarket Credentials (LIVE mode only) ──────────────────
# NEVER commit real values. Leave blank for paper trading.
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
PRIVATE_KEY=

# ── Risk / Safeguards ───────────────────────────────────────
MAX_CAPITAL_PER_TRADE_PCT=0.05
MIN_LIQUIDITY_USD=1000
MIN_RESOLUTION_HOURS=24
MAX_DAILY_LOSS_PCT=0.08
MAX_TOTAL_EXPOSURE_PCT=0.40
MAX_OPEN_POSITIONS=10

# ── Weather Strategy ────────────────────────────────────────
WEATHER_MISPRICING_THRESHOLD=0.15
WEATHER_SCAN_INTERVAL_S=1800
WEATHER_HISTORICAL_YEARS=5
WEATHER_ENSEMBLE_WEIGHT=0.70

# ── IA Probability Validator (Ollama) ───────────────────────
VALIDATOR_ENABLED=true
VALIDATOR_MODEL=phi3:mini
VALIDATOR_OLLAMA_URL=http://localhost:11434
VALIDATOR_TIMEOUT_S=30
VALIDATOR_MIN_CONFIDENCE=60
VALIDATOR_EDGE_THRESHOLD=0.15

# ── Whale Copy-Trade (optional) ─────────────────────────────
# Format: "Label:EOA[:proxy1,proxy2];Label2:EOA2"
WHALE_WALLETS=
POLYGON_WSS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
COPY_MAX_POSITION_PCT=0.03
